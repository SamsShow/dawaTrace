# ============================================================
# DawaTrace — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- Hyperledger Fabric ---
FABRIC_GATEWAY_ENDPOINT=localhost:7051
FABRIC_TLS_CERT_PATH=./fabric/network/crypto-config/peerOrganizations/org-mfg.dawaTrace.com/peers/peer0.org-mfg.dawaTrace.com/tls/ca.crt
FABRIC_CHANNEL_NAME=dawaTrace-channel
FABRIC_CHAINCODE_NAME=dawaTrace
FABRIC_MSP_ID=OrgMfgMSP
FABRIC_CERT_PATH=./fabric/network/crypto-config/peerOrganizations/org-mfg.dawaTrace.com/users/Admin@org-mfg.dawaTrace.com/msp/signcerts/Admin@org-mfg.dawaTrace.com-cert.pem
FABRIC_KEY_PATH=./fabric/network/crypto-config/peerOrganizations/org-mfg.dawaTrace.com/users/Admin@org-mfg.dawaTrace.com/msp/keystore/

# --- Sui ---
SUI_RPC_URL=https://fullnode.devnet.sui.io:443
SUI_NETWORK=devnet

# --- Bridge Relay (C-DAC signer — KEEP SECURE) ---
BRIDGE_SUI_PRIVATE_KEY=<Ed25519 hex private key — never commit>
BRIDGE_CAPABILITY_ID=<Sui Object ID of BridgeCapability — set after sui-deploy>
BRIDGE_PACKAGE_ID=<Published Sui package ID — set after sui-deploy>
BRIDGE_HEALTH_PORT=4001

# --- Redis (bridge retry queue) ---
REDIS_URL=redis://localhost:6379

# --- API Gateway ---
API_PORT=3000
API_JWT_SECRET=<change-me-in-production>
API_CORS_ORIGINS=http://localhost:5173,http://localhost:19006

# --- Web Dashboard ---
VITE_API_URL=http://localhost:3000
VITE_GRAPHQL_URL=http://localhost:3000/graphql
VITE_WS_URL=ws://localhost:3000/graphql
VITE_SUI_RPC_URL=https://fullnode.devnet.sui.io:443

# --- Mobile App ---
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SUI_RPC_URL=https://fullnode.devnet.sui.io:443
EXPO_PUBLIC_SUI_NETWORK=devnet
